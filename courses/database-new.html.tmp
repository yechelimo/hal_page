<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数据库原理与应用 - hal的学习空间</title>
    <meta name="description" content="数据库原理与应用课程，学习数据库的基本原理和应用，掌握SQL语言和数据库设计，了解数据库管理系统的工作原理。">
    <meta name="keywords" content="数据库, SQL, 关系数据库, 数据库设计, 数据库管理系统, 主键, 外键, 范式">
    <meta name="author" content="hal">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',
                        secondary: '#1E293B',
                        accent: '#3B82F6',
                        accent2: '#10B981',
                        light: '#F8FAFC',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                },
            }
        }
    </script>
    <link rel="stylesheet" href="../css/style.css">
</head>
<body class="bg-tech min-h-screen text-light overflow-x-hidden">
    <!-- 滚动进度条 -->
    <div id="scrollProgress" class="scroll-progress" style="width: 0%;"></div>
    
    <!-- 光标跟随效果 -->
    <div id="cursorFollower" class="cursor-follower"></div>
    
    <!-- 回到顶部按钮 -->
    <button id="backToTop" class="back-to-top">
        <i class="fa fa-arrow-up"></i>
    </button>
    
    <!-- 粒子背景 -->
    <div id="particles" class="fixed inset-0 pointer-events-none z-0"></div>
    
    <!-- 星星背景 -->
    <div class="fixed inset-0 pointer-events-none z-0" id="stars"></div>

    <!-- 导航栏 -->
    <nav class="glass-dark fixed top-0 left-0 right-0 z-50 shadow-xl transition-all duration-300">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <div class="text-accent font-bold text-xl flex items-center">
                <i class="fa fa-graduation-cap mr-3 text-2xl"></i>
                <span>hal的学习空间</span>
            </div>
            <div class="hidden md:flex space-x-8">
                <a href="../index.html" class="text-light hover:text-accent transition-colors duration-300">首页</a>
                <a href="#learn" class="text-light hover:text-accent transition-colors duration-300 active">学习</a>
                <a href="#practice" class="text-light hover:text-accent transition-colors duration-300">练习</a>
                <a href="#exam" class="text-light hover:text-accent transition-colors duration-300">考试</a>
            </div>
            <div class="md:hidden">
                <button id="mobileMenuBtn" class="text-light hover:text-accent transition-colors duration-300">
                    <i class="fa fa-bars text-xl"></i>
                </button>
            </div>
        </div>
        <!-- 移动端菜单 -->
        <div id="mobileMenu" class="mobile-menu hidden md:hidden glass-dark border-t border-white/10">
            <div class="container mx-auto px-4 py-4 space-y-4">
                <a href="../index.html" class="block text-light hover:text-accent transition-colors duration-300 py-2">首页</a>
                <a href="#learn" class="block text-light hover:text-accent transition-colors duration-300 py-2 active">学习</a>
                <a href="#practice" class="block text-light hover:text-accent transition-colors duration-300 py-2">练习</a>
                <a href="#exam" class="block text-light hover:text-accent transition-colors duration-300 py-2">考试</a>
            </div>
        </div>
    </nav>

    <!-- 主内容区域 -->
    <main class="pt-20">
        <!-- Learn页面 -->
        <section id="learn" class="min-h-screen py-16">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                    <!-- 侧边栏 - 章节导航 -->
                    <aside class="lg:col-span-1">
                        <div class="glass rounded-2xl p-6 border border-white/5 sticky top-24">
                            <h3 class="text-xl font-semibold mb-6 text-accent">课程章节</h3>
                            <div class="space-y-3" id="chapterList">
                                <!-- 章节列表将由JavaScript动态生成 -->
                            </div>
                        </div>
                    </aside>

                    <!-- 主内容区 -->
                    <article class="lg:col-span-3">
                        <div class="glass rounded-2xl p-8 md:p-12 border border-white/5">
                            <!-- 章节标题 -->
                            <div class="mb-8">
                                <h1 id="chapterTitle" class="text-3xl md:text-4xl font-bold mb-4">
                                    <span class="text-gradient">数据库概述</span>
                                </h1>
                                <div class="flex items-center space-x-4 text-gray-400">
                                    <span><i class="fa fa-clock-o mr-2"></i>预计学习时间：<span class="chapter-info-duration">30分钟</span></span>
                                    <span class="chapter-info-difficulty"><i class="fa fa-book mr-2"></i>难度：入门</span>
                                </div>
                            </div>

                            <!-- 章节导学 -->
                            <div class="chapter-intro mb-12">
                                <h3 class="text-xl font-semibold mb-4 text-accent flex items-center">
                                    <i class="fa fa-book mr-2"></i>章节导学
                                </h3>
                                <p class="text-gray-300 leading-relaxed">
                                    本章将介绍数据库的基本概念、发展历史和分类，帮助你建立对数据库的整体认识。
                                </p>
                            </div>

                            <!-- 主要内容 -->
                            <div class="chapter-content mb-12">
                                <!-- 章节内容将由JavaScript动态生成 -->
                            </div>

                            <!-- 本章小结 -->
                            <div class="mb-12">
                                <h3 class="text-xl font-semibold mb-4 text-accent flex items-center">
                                    <i class="fa fa-check-circle mr-2"></i>本章小结
                                </h3>
                                <div class="overflow-x-auto">
                                    <table class="w-full summary-table">
                                        <thead>
                                            <tr class="border-b border-white/10">
                                                <th class="text-left py-3 px-4 text-gray-400">知识点</th>
                                                <th class="text-left py-3 px-4 text-gray-400">内容</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!-- 小结内容将由JavaScript动态生成 -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- 随堂练习 -->
                            <div class="in-class-exercises mb-12">
                                <h3 class="text-xl font-semibold mb-4 text-accent flex items-center">
                                    <i class="fa fa-pencil mr-2"></i>随堂练习
                                </h3>
                                <div class="space-y-4">
                                    <!-- 练习内容将由JavaScript动态生成 -->
                                </div>
                            </div>

                            <!-- 导航按钮 -->
                            <div class="flex justify-between items-center pt-8 border-t border-white/10">
                                <button class="prev-chapter-btn bg-white/10 hover:bg-white/20 transition-colors duration-300 px-6 py-3 rounded-lg flex items-center" onclick="goToPrevChapter()">
                                    <i class="fa fa-arrow-left mr-2"></i>上一章
                                </button>
                                <button class="next-chapter-btn bg-accent hover:bg-accent/90 transition-colors duration-300 px-8 py-3 rounded-lg flex items-center" onclick="goToNextChapter()">
                                    <span>下一章</span>
                                    <i class="fa fa-arrow-right ml-2"></i>
                                </button>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <!-- Practice页面 -->
        <section id="practice" class="min-h-screen py-16 hidden">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold mb-4">
                        <span class="text-gradient">数据库练习</span>
                    </h2>
                    <p class="text-gray-400 text-lg">通过练习巩固所学知识</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                    <!-- 章节选择 -->
                    <aside class="lg:col-span-1">
                        <div class="glass rounded-2xl p-6 border border-white/5 sticky top-24">
                            <h3 class="text-xl font-semibold mb-6 text-accent">练习章节</h3>
                            <select id="chapterSelect" class="w-full bg-black/30 border border-white/20 rounded-lg px-4 py-3 text-light focus:outline-none focus:border-accent transition-colors duration-300">
                                <!-- 章节选项将由JavaScript动态生成 -->
                            </select>
                        </div>
                    </aside>

                    <!-- 练习区域 -->
                    <div class="lg:col-span-3">
                        <!-- 题目列表 -->
                        <div class="practice-header glass rounded-2xl p-6 border border-white/5 mb-8">
                            <h3 class="text-xl font-semibold mb-6 text-accent">数据库原理与应用 - 第一章：数据库概述</h3>
                            <div class="grid grid-cols-3 md:grid-cols-5 lg:grid-cols-7 gap-3 mb-6" id="problemList">
                                <!-- 题目列表将由JavaScript动态生成 -->
                            </div>
                        </div>

                        <!-- 题目详情和编辑器 -->
                        <div class="glass rounded-2xl p-8 border border-white/5">
                            <!-- 题目内容 -->
                            <div class="mb-8">
                                <h4 class="text-xl font-semibold mb-4" id="problemTitle">1. 数据库定义</h4>
                                <p class="problem-description text-gray-300 leading-relaxed mb-4">以下关于数据库的定义，正确的是：</p>
                                
                                <div class="problem-input bg-black/30 rounded-lg p-4 mb-4">
                                    <h5 class="text-sm font-semibold mb-2 text-gray-400">输入</h5>
                                    <p class="text-gray-300">无</p>
                                </div>
                                
                                <div class="problem-output bg-black/30 rounded-lg p-4">
                                    <h5 class="text-sm font-semibold mb-2 text-gray-400">输出</h5>
                                    <p class="text-gray-300">正确答案</p>
                                </div>
                            </div>

                            <!-- 代码编辑器 -->
                            <div class="code-editor-container mb-8">
                                <h5 class="text-lg font-semibold mb-4 text-accent flex items-center justify-between">
                                    <span>SQL编辑器</span>
                                    <button id="resetBtn" class="text-sm text-gray-400 hover:text-accent transition-colors duration-300">
                                        <i class="fa fa-refresh mr-1"></i>重置
                                    </button>
                                </h5>
                                <textarea id="codeEditor" class="w-full h-64 bg-black/40 border border-white/20 rounded-lg p-4 text-light font-mono text-sm focus:outline-none focus:border-accent transition-colors duration-300 resize-none" placeholder="-- 在下方编写SQL语句"></textarea>
                            </div>

                            <!-- 多选题目容器 -->
                            <div class="multiple-choice-container mb-8 hidden">
                                <h5 class="text-lg font-semibold mb-4 text-accent">选择答案</h5>
                                <div class="multiple-choice-options space-y-3">
                                    <!-- 选项将由JavaScript动态生成 -->
                                </div>
                            </div>

                            <!-- 判断题容器 -->
                            <div class="true-false-container mb-8 hidden">
                                <h5 class="text-lg font-semibold mb-4 text-accent">判断正误</h5>
                                <div class="space-y-3">
                                    <div class="option-item">
                                        <input type="radio" id="true-option" name="true-false" value="true" class="mr-2">
                                        <label for="true-option" class="cursor-pointer">正确</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="false-option" name="true-false" value="false" class="mr-2">
                                        <label for="false-option" class="cursor-pointer">错误</label>
                                    </div>
                                </div>
                            </div>

                            <!-- 输出区域 -->
                            <div class="mb-8">
                                <h5 class="text-lg font-semibold mb-4 text-accent">运行结果</h5>
                                <div id="outputArea" class="bg-black/30 rounded-lg p-4 min-h-24">
                                    <span class="text-gray-500">点击"运行代码"查看输出结果</span>
                                </div>
                            </div>

                            <!-- 按钮组 -->
                            <div class="flex flex-wrap gap-4">
                                <button id="runBtn" class="bg-accent hover:bg-accent/90 transition-colors duration-300 px-6 py-3 rounded-lg flex items-center">
                                    <i class="fa fa-play mr-2"></i>运行SQL
                                </button>
                                <button id="submitBtn" class="bg-green-500 hover:bg-green-500/90 transition-colors duration-300 px-6 py-3 rounded-lg flex items-center">
                                    <i class="fa fa-check mr-2"></i>提交答案
                                </button>
                                <div class="ml-auto flex space-x-4">
                                    <button class="prev-problem-btn bg-white/10 hover:bg-white/20 transition-colors duration-300 px-4 py-3 rounded-lg flex items-center">
                                        <i class="fa fa-arrow-left mr-2"></i>上一题
                                    </button>
                                    <button class="next-problem-btn bg-white/10 hover:bg-white/20 transition-colors duration-300 px-4 py-3 rounded-lg flex items-center">
                                        <span>下一题</span>
                                        <i class="fa fa-arrow-right ml-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Exam页面 -->
        <section id="exam" class="min-h-screen py-16 hidden">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold mb-4">
                        <span class="text-gradient">课程考试</span>
                    </h2>
                    <p class="text-gray-400 text-lg">测试您的学习成果</p>
                </div>

                <div class="glass rounded-2xl p-8 md:p-12 border border-white/5 max-w-3xl mx-auto">
                    <div class="mb-8">
                        <h3 class="text-2xl font-semibold mb-4 text-accent">数据库原理与应用课程考试</h3>
                        <p class="text-gray-400">本次考试共有10道题目，包括单选题、多选题和判断题。请认真作答。</p>
                    </div>

                    <div class="exam-content">
                        <h4 class="text-xl font-semibold mb-6">考试题目</h4>
                        
                        <div class="space-y-8">
                            <!-- 题目1：单选题 -->
                            <div class="exam-question">
                                <h5 class="text-lg font-semibold mb-4">1. 以下哪种数据库类型是最常用的？</h5>
                                <div class="space-y-3">
                                    <div class="option-item">
                                        <input type="radio" id="q1-option1" name="q1" value="A" class="mr-2">
                                        <label for="q1-option1" class="cursor-pointer">A. 层次数据库</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q1-option2" name="q1" value="B" class="mr-2">
                                        <label for="q1-option2" class="cursor-pointer">B. 网状数据库</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q1-option3" name="q1" value="C" class="mr-2">
                                        <label for="q1-option3" class="cursor-pointer">C. 关系数据库</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q1-option4" name="q1" value="D" class="mr-2">
                                        <label for="q1-option4" class="cursor-pointer">D. NoSQL数据库</label>
                                    </div>
                                </div>
                            </div>

                            <!-- 题目2：单选题 -->
                            <div class="exam-question">
                                <h5 class="text-lg font-semibold mb-4">2. 以下哪个SQL语句用于查询数据？</h5>
                                <div class="space-y-3">
                                    <div class="option-item">
                                        <input type="radio" id="q2-option1" name="q2" value="A" class="mr-2">
                                        <label for="q2-option1" class="cursor-pointer">A. INSERT</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q2-option2" name="q2" value="B" class="mr-2">
                                        <label for="q2-option2" class="cursor-pointer">B. UPDATE</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q2-option3" name="q2" value="C" class="mr-2">
                                        <label for="q2-option3" class="cursor-pointer">C. SELECT</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q2-option4" name="q2" value="D" class="mr-2">
                                        <label for="q2-option4" class="cursor-pointer">D. DELETE</label>
                                    </div>
                                </div>
                            </div>

                            <!-- 题目3：判断题 -->
                            <div class="exam-question">
                                <h5 class="text-lg font-semibold mb-4">3. 主键可以为空值。</h5>
                                <div class="space-y-3">
                                    <div class="option-item">
                                        <input type="radio" id="q3-option1" name="q3" value="true" class="mr-2">
                                        <label for="q3-option1" class="cursor-pointer">正确</label>
                                    </div>
                                    <div class="option-item">
                                        <input type="radio" id="q3-option2" name="q3" value="false" class="mr-2">
                                        <label for="q3-option2" class="cursor-pointer">错误</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 flex justify-center">
                        <button class="bg-accent hover:bg-accent/90 transition-colors duration-300 px-8 py-4 rounded-lg flex items-center text-lg font-medium">
                            <i class="fa fa-check-circle mr-2"></i>提交考试
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="js/database.js"></script>
</body>
</html>